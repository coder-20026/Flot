<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_md"
    app:cardCornerRadius="@dimen/corner_radius_xl"
    app:cardElevation="@dimen/elevation_lg"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_card">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivStatus"
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:src="@drawable/ic_check"
                android:contentDescription="@string/result_title"
                app:tint="@color/success" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:text="@string/result_title"
                android:textAppearance="@style/TextAppearance.CoordinateExtractor.Title"
                android:textColor="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="@dimen/icon_size_lg"
                android:layout_height="@dimen/icon_size_lg"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_close"
                android:contentDescription="@string/cd_close_button"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- Raw Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/result_raw_text"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvRawText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:background="@drawable/bg_button_ripple"
            android:padding="@dimen/spacing_sm"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="3"
            android:ellipsize="end"
            tools:text="Mar 28, 2026 10:36am 22.1234N 71.1234E Borsad Gujarat" />

        <!-- Coordinates -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/result_coordinates"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvCoordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:background="@drawable/bg_button_ripple"
            android:padding="@dimen/spacing_md"
            android:textAppearance="@style/TextAppearance.CoordinateExtractor.Coordinate"
            android:textSize="@dimen/text_size_title"
            android:gravity="center"
            tools:text="22.123456,71.123456" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopy"
                style="@style/Widget.CoordinateExtractor.Button.Tonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_copy"
                app:icon="@drawable/ic_copy"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMaps"
                style="@style/Widget.CoordinateExtractor.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="@string/btn_open_maps"
                app:icon="@drawable/ic_map"
                app:iconGravity="textStart" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark Theme -->
    <style name="Theme.CoordinateExtractor" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant_dark</item>
        <item name="colorOnPrimary">@color/on_primary_dark</item>
        <item name="colorPrimaryContainer">@color/primary_variant_dark</item>
        <item name="colorOnPrimaryContainer">@color/primary_dark</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/on_secondary_dark</item>
        <item name="colorSecondaryContainer">@color/secondary_dark</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_dark</item>

        <!-- Tertiary Colors -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>

        <!-- Background Colors -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorOnBackground">@color/on_background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_dark</item>

        <!-- Error Colors -->
        <item name="colorError">@color/error_dark</item>
        <item name="colorOnError">@color/on_error_dark</item>

        <!-- Outline Colors -->
        <item name="colorOutline">@color/outline_dark</item>
        <item name="colorOutlineVariant">@color/outline_variant_dark</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Dark Transparent Theme -->
    <style name="Theme.CoordinateExtractor.Transparent" parent="Theme.CoordinateExtractor">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- Dark Bottom Sheet Theme -->
    <style name="Theme.CoordinateExtractor.BottomSheet" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="bottomSheetStyle">@style/Widget.CoordinateExtractor.BottomSheet.Dark</item>
    </style>

    <style name="Widget.CoordinateExtractor.BottomSheet.Dark" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@color/surface_dark</item>
        <item name="shapeAppearance">@style/ShapeAppearance.CoordinateExtractor.BottomSheet</item>
    </style>
</resources>
